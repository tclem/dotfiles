{
  "editor.formatOnPaste": true,
  "files.autoSave": "onFocusChange",
  "editor.fontSize": 14,
  "editor.renderWhitespace": "boundary",
  "editor.fontFamily": "SF Mono, Menlo, Monaco, 'Courier New', monospace",
  "editor.minimap.enabled": false,
  "workbench.colorTheme": "Atom One Dark",
  "files.trimFinalNewlines": true,
  "outline.problems.enabled": false,
  "outline.problems.badges": false,
  "outline.problems.colors": false,
  "problems.decorations.enabled": false,
  "search.exclude": {
    "**/.git": true
  },
  "telemetry.telemetryLevel": "crash",
  "vim.useSystemClipboard": true,
  "vim.useCtrlKeys": false,
  "go.useLanguageServer": true,
  "files.insertFinalNewline": true,
  "workbench.startupEditor": "newUntitledFile",
  "explorer.autoReveal": false,
  "workbench.editor.enablePreviewFromQuickOpen": false,
  "workbench.enableExperiments": false,
  "workbench.statusBar.visible": true,
  "terminal.external.osxExec": "iTerm.app",
  "terminal.integrated.fontSize": 14,
  "openInGitHub.defaultBranch": "main",
  "openInGitHub.repositoryType": "github",
  "diffEditor.renderSideBySide": false,
  "git.confirmSync": false,
  "go.delveConfig": {
    "dlvLoadConfig": {
      "followPointers": true,
      "maxVariableRecurse": 1,
      "maxStringLen": 1024,
      "maxArrayValues": 64,
      "maxStructFields": -1
    },
    "apiVersion": 2,
    "showGlobalVariables": false
  },
  "terminal.integrated.shell.linux": "/bin/zsh",
  "terminal.integrated.shell.osx": "/opt/homebrew/bin/zsh",
  "terminal.integrated.automationShell.osx": "/opt/homebrew/bin/zsh",
  "go.toolsManagement.autoUpdate": true,
  "files.trimTrailingWhitespace": true,
  "editor.cursorStyle": "line",
  "editor.lineNumbers": "on",
  "editor.wordSeparators": "/\\()\"':,.;<>~!@#$%^&*|+=[]{}`?-",
  "editor.wordWrap": "off",
  "editor.tabSize": 2,
  "editor.detectIndentation": true,
  "[cpp]": {
    "editor.wordBasedSuggestions": "off",
    "editor.suggest.insertMode": "replace",
    "editor.semanticHighlighting.enabled": true
  },
  "[rust]": {
    "editor.formatOnSave": true
  },
  "[shellscript]": {
    "editor.tabSize": 4,
    "files.eol": "\n"
  },
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.maxTokenizationLineLength": 2500
  },
  "[yaml]": {
    "editor.formatOnSave": false
  },
  "[python]": {
    "editor.tabSize": 4,
    "editor.insertSpaces": true
  },
  "git.autofetch": true,
  "security.workspace.trust.untrustedFiles": "open",
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "jupyter.askForKernelRestart": false,
  "pythonTestExplorer.testFramework": "unittest",
  "editor.inlineSuggest.enabled": true,
  "rust-analyzer.cargo.features": "all",
  "rust-analyzer.procMacro.enable": true,
  "rust-analyzer.cargo.buildScripts.enable": true,
  "rust-analyzer.imports.granularity.group": "module",
  "rust-analyzer.imports.granularity.enforce": true,
  "rust-analyzer.checkOnSave": true,
  "rust-analyzer.check.extraArgs": [
    "--target-dir",
    "/tmp/rust-analyzer-check"
  ],
  "markdown.extension.toc.levels": "2..6",
  "[markdown]": {
    "editor.defaultFormatter": "yzhang.markdown-all-in-one"
  },
  "github.copilot.enable": {
    "*": true,
    "plaintext": false,
    "markdown": true,
    "scminput": false,
    "go": true,
    "rust": true,
    "jsonc": false
  },
  "gopls": {
    "ui.semanticTokens": true
  },
  "terminal.integrated.copyOnSelection": true,
  "workbench.layoutControl.enabled": false,
  "particle.maxAllowedToolchains": 6,
  "githubPullRequests.pullBranch": "never",
  "window.newWindowDimensions": "inherit",
  "terminal.integrated.allowChords": false,
  "editor.multiCursorModifier": "alt",
  "githubPullRequests.commentExpandState": "collapseAll",
  "[html]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "workbench.activityBar.location": "hidden",
  "[jsonc]": {
    "editor.defaultFormatter": "vscode.json-language-features"
  },
  "typespec.tsp-server.path": "${workspaceFolder}/api/node_modules/@typespec/compiler",
  "evenBetterToml.formatter.columnWidth": 80,
  "evenBetterToml.formatter.allowedBlankLines": 1,
  "terminal.integrated.defaultProfile.linux": "zsh",
  "editor.wordWrapColumn": 120,
  "prettier.requirePragma": true,
  "diffEditor.experimental.showMoves": true,
  "[html.erb]": {
    "editor.defaultFormatter": "aliariff.vscode-erb-beautify",
    "editor.formatOnSave": true
  },
  "[erb]": {
    "editor.defaultFormatter": "aliariff.vscode-erb-beautify"
  },
  "lldb.suppressUpdateNotifications": true,
  "evenBetterToml.formatter.arrayAutoExpand": false,
  "evenBetterToml.formatter.arrayAutoCollapse": false,
  "[javascriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "editor.codeActionsOnSave": {},
  "remote.autoForwardPortsSource": "hybrid",
  "chat.editing.alwaysSaveWithGeneratedChanges": true,
  "git.blame.editorDecoration.enabled": false,
  "cSpell.userWords": [
    "typespec"
  ],
  "settingsSync.ignoredExtensions": [
    "devsense.composer-php-vscode",
    "devsense.intelli-php-vscode",
    "devsense.phptools-vscode",
    "devsense.profiler-php-vscode"
  ],
  "spellright.notificationClass": "hint",
  "spellright.language": [
    "en"
  ],
  "spellright.documentTypes": [
    "markdown",
    "plaintext",
    "rust",
    "go"
  ],
  "chat.agent.enabled": true,
  "editor.inlineSuggest.edits.allowCodeShifting": "never",
  "github.copilot.chat.codesearch.enabled": true,
  // "github.copilot.chat.advanced.workspace.enableEmbeddingsSearch": false,
  "github.copilot.nextEditSuggestions.enabled": true,
  "spellright.spellContext": "comments strings",
  "terminal.integrated.cursorBlinking": true,
  "editor.gotoLocation.multipleDefinitions": "goto",
  "editor.gotoLocation.multipleDeclarations": "goto",
  "chat.mcp.gallery.enabled": true,
  "rust-analyzer.cargo.buildScripts.overrideCommand": null,
  "rust-analyzer.cargo.allTargets": false,
  "chat.viewSessions.orientation": "stacked",
  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "github.copilot.chat.githubMcpServer.enabled": true,
  "github.copilot.chat.githubMcpServer.readonly": true,
  "javascript.updateImportsOnFileMove.enabled": "always",
  "github.copilot.chat.advanced.workspace.codeSearchExternalIngest.enabled": "force",
  "@azure.argTenant": ""
}
