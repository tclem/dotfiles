#!/bin/bash
#
# Sync portable copilot config between this repo and ~/.copilot.
#
#   script/sync-copilot install   — symlink repo files into ~/.copilot
#   script/sync-copilot import    — copy new files from ~/.copilot into the repo, then symlink

set -euo pipefail

DOTFILES_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
COPILOT_HOME="$HOME/.copilot"
COPILOT_REPO="$DOTFILES_ROOT/copilot"

# Portable paths (relative to copilot root) that we sync.
# Globs are expanded against the source directory for each direction.
PORTABLE_GLOBS=(
  "copilot-instructions.md"
  "agents/*.agent.md"
  "skills/*/SKILL.md"
  "docs/*"
)

green()  { printf "\033[32m%s\033[0m\n" "$1"; }
yellow() { printf "\033[33m%s\033[0m\n" "$1"; }

# Return 0 if the SKILL.md at $1 has `disabled: true` in its frontmatter, else 1.
# Frontmatter is the leading `---`-delimited YAML block. Anything outside is ignored.
is_disabled_skill() {
  local file="$1"
  [[ -f "$file" ]] || return 1
  awk '
    NR==1 && /^---[[:space:]]*$/ { in_fm=1; next }
    in_fm && /^---[[:space:]]*$/ { exit }
    in_fm && /^disabled:[[:space:]]*true[[:space:]]*$/ { found=1; exit }
    END { exit !found }
  ' "$file"
}

# Expand globs against a root directory, returning paths relative to that root.
expand_globs() {
  local root="$1"
  shift
  local results=()
  for glob in "$@"; do
    # Use find-like expansion via bash globbing
    for f in "$root"/$glob; do
      [[ -f "$f" || -L "$f" ]] && results+=("${f#$root/}")
    done
  done
  printf '%s\n' "${results[@]}"
}

prune_removed_links() {
  local files="$1"
  local installed
  installed=$(expand_globs "$COPILOT_HOME" "${PORTABLE_GLOBS[@]}")

  while IFS= read -r rel; do
    [[ -z "$rel" ]] && continue
    grep -qxF "$rel" <<< "$files" && continue

    local dst="$COPILOT_HOME/$rel"
    [[ -L "$dst" ]] || continue

    local target
    target=$(readlink "$dst")
    if [[ "$target" == "$COPILOT_REPO/"* ]]; then
      rm "$dst"
      rmdir -p "$(dirname "$dst")" 2>/dev/null || true
      yellow "  removed $rel"
    fi
  done <<< "$installed"
}

cmd_install() {
  echo "Installing copilot config: $COPILOT_REPO → $COPILOT_HOME"
  local files filtered=() skipped=()
  files=$(expand_globs "$COPILOT_REPO" "${PORTABLE_GLOBS[@]}")

  while IFS= read -r rel; do
    [[ -z "$rel" ]] && continue
    local src="$COPILOT_REPO/$rel"

    if [[ "$rel" == skills/*/SKILL.md ]] && is_disabled_skill "$src"; then
      skipped+=("$rel")
      continue
    fi

    filtered+=("$rel")
    local dst="$COPILOT_HOME/$rel"
    mkdir -p "$(dirname "$dst")"
    ln -sf "$src" "$dst"
    green "  linked $rel"
  done <<< "$files"

  local filtered_list
  filtered_list=$(printf '%s\n' "${filtered[@]}")
  prune_removed_links "$filtered_list"

  if (( ${#skipped[@]} > 0 )); then
    echo
    yellow "Skipped (disabled: true):"
    for rel in "${skipped[@]}"; do
      yellow "  $rel"
    done
  fi
}

cmd_import() {
  echo "Importing copilot config: $COPILOT_HOME → $COPILOT_REPO"
  local files
  files=$(expand_globs "$COPILOT_HOME" "${PORTABLE_GLOBS[@]}")

  while IFS= read -r rel; do
    [[ -z "$rel" ]] && continue
    local src="$COPILOT_HOME/$rel"
    local dst="$COPILOT_REPO/$rel"

    # Skip if already a symlink pointing into the repo
    if [[ -L "$src" ]]; then
      local target
      target=$(readlink "$src")
      if [[ "$target" == "$COPILOT_REPO"* ]]; then
        yellow "  skip $rel (already linked)"
        continue
      fi
    fi

    mkdir -p "$(dirname "$dst")"
    cp "$src" "$dst"
    ln -sf "$dst" "$src"
    green "  imported $rel"
  done <<< "$files"
}

case "${1:-}" in
  install) cmd_install ;;
  import)  cmd_import ;;
  *)
    echo "Usage: script/sync-copilot {install|import}"
    exit 1
    ;;
esac
