#!/bin/bash
#
# Clean up worktrees and tmux session for a Copilot agent project.
#
# Usage: agent-cleanup <project> [<branch>]
#        agent-cleanup [-l] <project>
#
#   -l  Local mode: skip worktree/branch cleanup (tmux session only)

set -euo pipefail

WORKTREE_ROOT="${WORKTREE_ROOT:-$HOME/github/.worktrees}"
PROJECTS_DIR="${PROJECTS:-$HOME/github}"
CONFIG="${COPILOT_AGENT_CONFIG:-$HOME/.config/copilot-agent/projects.conf}"
LOCAL_MODE=false

usage() {
  echo "Usage: agent-cleanup <project> <branch>"
  echo "       agent-cleanup [-l] <project>"
  echo ""
  echo "  -l  Local mode: skip worktree/branch cleanup"
  exit 1
}

parse_config() {
  local project="$1"
  local config_file="$2"
  local in_section=false

  PROJECT_REPOS=()
  PROJECT_LOCAL=false

  if [[ ! -f "$config_file" ]]; then
    echo "Error: config file not found: $config_file" >&2
    exit 1
  fi

  while IFS= read -r line || [[ -n "$line" ]]; do
    line="${line%%#*}"
    line="${line## }"
    line="${line%% }"
    [[ -z "$line" ]] && continue

    if [[ "$line" =~ ^\[(.+)\]$ ]]; then
      if [[ "${BASH_REMATCH[1]}" == "$project" ]]; then
        in_section=true
      else
        $in_section && break
      fi
      continue
    fi

    $in_section || continue

    local key="${line%%=*}"
    local val="${line#*=}"
    key="${key## }"
    key="${key%% }"
    val="${val## }"
    val="${val%% }"

    case "$key" in
      repos) read -ra PROJECT_REPOS <<< "$val" ;;
      local) [[ "$val" == "true" ]] && PROJECT_LOCAL=true ;;
    esac
  done < "$config_file"

  if [[ ${#PROJECT_REPOS[@]} -eq 0 ]]; then
    echo "Error: project '$project' not found or has no repos" >&2
    exit 1
  fi
}

repo_name() {
  local entry="${1%%:*}"
  echo "${entry##*/}"
}

while getopts ":l" opt; do
  case $opt in
    l) LOCAL_MODE=true ;;
    *) usage ;;
  esac
done
shift $((OPTIND - 1))

[[ $# -ge 1 ]] || usage

project="$1"
branch="${2:-}"

parse_config "$project" "$CONFIG"

# Config-level local=true overrides the flag
if $PROJECT_LOCAL; then
  LOCAL_MODE=true
fi

if ! $LOCAL_MODE && [[ -z "$branch" ]]; then
  echo "Error: branch required for non-local project '$project'" >&2
  usage
fi

# Kill tmux session if it exists
if tmux has-session -t "$project" 2>/dev/null; then
  echo "Killing tmux session: $project"
  tmux kill-session -t "$project"
fi

# Remove worktrees (skip in local mode)
if ! $LOCAL_MODE; then
  for repo in "${PROJECT_REPOS[@]}"; do
    name="$(repo_name "$repo")"
    repo_dir="$PROJECTS_DIR/$name"
    wt_dir="$WORKTREE_ROOT/$name/$branch"

    if [[ -d "$wt_dir" ]]; then
      if [[ -n "$(git -C "$wt_dir" status --porcelain 2>/dev/null)" ]]; then
        echo "WARNING: $wt_dir has uncommitted changes:"
        git -C "$wt_dir" status --short
        read -rp "Remove anyway? [y/N] " confirm
        [[ "$confirm" =~ ^[Yy]$ ]] || { echo "Skipping $wt_dir"; continue; }
      fi
      echo "Removing worktree: $wt_dir"
      git -C "$repo_dir" worktree remove "$wt_dir" --force
      echo "Deleting branch: $branch (in $name)"
      git -C "$repo_dir" branch -D "$branch" 2>/dev/null || true
    else
      echo "Worktree not found (skipping): $wt_dir"
    fi
  done
fi

echo "Done."
